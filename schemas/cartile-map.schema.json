{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CartileMap",
  "type": "object",
  "required": [
    "cartile",
    "grid",
    "name",
    "type"
  ],
  "properties": {
    "cartile": {
      "type": "string"
    },
    "grid": {
      "$ref": "#/definitions/Grid"
    },
    "layers": {
      "default": [],
      "type": "array",
      "items": {
        "$ref": "#/definitions/Layer"
      }
    },
    "name": {
      "type": "string"
    },
    "properties": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/definitions/Property"
      }
    },
    "tilesets": {
      "default": [],
      "type": "array",
      "items": {
        "$ref": "#/definitions/TilesetEntry"
      }
    },
    "type": {
      "type": "string"
    }
  },
  "additionalProperties": true,
  "definitions": {
    "AutoTile": {
      "type": "object",
      "required": [
        "bitmask",
        "group",
        "rule"
      ],
      "properties": {
        "bitmask": {
          "type": "integer",
          "format": "uint8",
          "minimum": 0.0
        },
        "group": {
          "type": "string"
        },
        "rule": {
          "$ref": "#/definitions/AutoTileRule"
        }
      }
    },
    "AutoTileRule": {
      "type": "string",
      "enum": [
        "bitmask_4bit",
        "bitmask_8bit"
      ]
    },
    "Grid": {
      "type": "object",
      "required": [
        "height",
        "projection",
        "tile_height",
        "tile_width",
        "type",
        "width"
      ],
      "properties": {
        "height": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0.0
        },
        "height_mode": {
          "default": "none",
          "allOf": [
            {
              "$ref": "#/definitions/HeightMode"
            }
          ]
        },
        "orientation": {
          "anyOf": [
            {
              "$ref": "#/definitions/HexOrientation"
            },
            {
              "type": "null"
            }
          ]
        },
        "projection": {
          "$ref": "#/definitions/Projection"
        },
        "stagger": {
          "anyOf": [
            {
              "$ref": "#/definitions/Stagger"
            },
            {
              "type": "null"
            }
          ]
        },
        "tile_height": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0.0
        },
        "tile_width": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0.0
        },
        "topology": {
          "default": "bounded",
          "allOf": [
            {
              "$ref": "#/definitions/Topology"
            }
          ]
        },
        "type": {
          "$ref": "#/definitions/GridType"
        },
        "width": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0.0
        }
      },
      "additionalProperties": true
    },
    "GridType": {
      "type": "string",
      "enum": [
        "square",
        "hexagonal"
      ]
    },
    "HeightMode": {
      "type": "string",
      "enum": [
        "none",
        "stepped",
        "vertex"
      ]
    },
    "HexOrientation": {
      "type": "string",
      "enum": [
        "flat_top",
        "pointy_top"
      ]
    },
    "Layer": {
      "description": "A map layer — either tile data, placed objects, or heightmap values.",
      "oneOf": [
        {
          "description": "A layer of tile IDs arranged in a flat array (row-major order).",
          "type": "object",
          "required": [
            "data",
            "name",
            "type"
          ],
          "properties": {
            "data": {
              "type": "array",
              "items": {
                "type": "integer",
                "format": "uint32",
                "minimum": 0.0
              }
            },
            "elevation": {
              "default": 0,
              "type": "integer",
              "format": "int32"
            },
            "encoding": {
              "default": "dense",
              "type": "string"
            },
            "name": {
              "type": "string"
            },
            "opacity": {
              "default": 1.0,
              "type": "number",
              "format": "double"
            },
            "properties": {
              "type": "object",
              "additionalProperties": {
                "$ref": "#/definitions/Property"
              }
            },
            "type": {
              "type": "string",
              "enum": [
                "tile"
              ]
            },
            "visible": {
              "default": true,
              "type": "boolean"
            }
          }
        },
        {
          "description": "A layer of placed map objects (entities, triggers, paths, etc.).",
          "type": "object",
          "required": [
            "name",
            "objects",
            "type"
          ],
          "properties": {
            "name": {
              "type": "string"
            },
            "objects": {
              "type": "array",
              "items": {
                "$ref": "#/definitions/MapObject"
              }
            },
            "opacity": {
              "default": 1.0,
              "type": "number",
              "format": "double"
            },
            "properties": {
              "type": "object",
              "additionalProperties": {
                "$ref": "#/definitions/Property"
              }
            },
            "type": {
              "type": "string",
              "enum": [
                "object"
              ]
            },
            "visible": {
              "default": true,
              "type": "boolean"
            }
          }
        },
        {
          "description": "A layer of signed integer height values for isometric/3D-ish maps.",
          "type": "object",
          "required": [
            "data",
            "name",
            "type"
          ],
          "properties": {
            "data": {
              "type": "array",
              "items": {
                "type": "integer",
                "format": "int32"
              }
            },
            "name": {
              "type": "string"
            },
            "opacity": {
              "default": 1.0,
              "type": "number",
              "format": "double"
            },
            "properties": {
              "type": "object",
              "additionalProperties": {
                "$ref": "#/definitions/Property"
              }
            },
            "type": {
              "type": "string",
              "enum": [
                "heightmap"
              ]
            },
            "visible": {
              "default": true,
              "type": "boolean"
            }
          }
        }
      ]
    },
    "MapObject": {
      "description": "A map object placed in an ObjectLayer, using pixel coordinates.",
      "type": "object",
      "required": [
        "id",
        "shape",
        "x",
        "y"
      ],
      "properties": {
        "height": {
          "type": "number",
          "format": "double"
        },
        "id": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0.0
        },
        "name": {
          "type": "string"
        },
        "points": {
          "type": [
            "array",
            "null"
          ],
          "items": {
            "$ref": "#/definitions/Point"
          }
        },
        "properties": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/definitions/Property"
          }
        },
        "rotation": {
          "type": "number",
          "format": "double"
        },
        "shape": {
          "$ref": "#/definitions/Shape"
        },
        "width": {
          "type": "number",
          "format": "double"
        },
        "x": {
          "type": "number",
          "format": "double"
        },
        "y": {
          "type": "number",
          "format": "double"
        }
      },
      "additionalProperties": true
    },
    "Point": {
      "description": "A 2D point used in polygon/polyline definitions.",
      "type": "object",
      "required": [
        "x",
        "y"
      ],
      "properties": {
        "x": {
          "type": "number",
          "format": "double"
        },
        "y": {
          "type": "number",
          "format": "double"
        }
      }
    },
    "Projection": {
      "type": "object",
      "required": [
        "type"
      ],
      "properties": {
        "angle": {
          "type": [
            "number",
            "null"
          ],
          "format": "double"
        },
        "type": {
          "$ref": "#/definitions/ProjectionType"
        }
      },
      "additionalProperties": true
    },
    "ProjectionType": {
      "type": "string",
      "enum": [
        "orthogonal",
        "isometric",
        "oblique"
      ]
    },
    "Property": {
      "description": "A typed property value. The `type` field discriminates how `value` should be interpreted, allowing the editor and runtime to validate and display properties correctly without relying on JSON type inference alone.",
      "type": "object",
      "required": [
        "type",
        "value"
      ],
      "properties": {
        "type": {
          "$ref": "#/definitions/PropertyType"
        },
        "value": true
      }
    },
    "PropertyType": {
      "description": "Supported property types.",
      "type": "string",
      "enum": [
        "bool",
        "string",
        "int",
        "float",
        "color",
        "file"
      ]
    },
    "Shape": {
      "description": "The geometric shape of a map object.",
      "type": "string",
      "enum": [
        "point",
        "rect",
        "ellipse",
        "polygon",
        "polyline"
      ]
    },
    "Stagger": {
      "type": "object",
      "required": [
        "axis",
        "index"
      ],
      "properties": {
        "axis": {
          "$ref": "#/definitions/StaggerAxis"
        },
        "index": {
          "$ref": "#/definitions/StaggerIndex"
        }
      }
    },
    "StaggerAxis": {
      "type": "string",
      "enum": [
        "x",
        "y"
      ]
    },
    "StaggerIndex": {
      "type": "string",
      "enum": [
        "odd",
        "even"
      ]
    },
    "TileData": {
      "type": "object",
      "properties": {
        "auto_tile": {
          "anyOf": [
            {
              "$ref": "#/definitions/AutoTile"
            },
            {
              "type": "null"
            }
          ]
        },
        "properties": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/definitions/Property"
          }
        }
      },
      "additionalProperties": true
    },
    "Tileset": {
      "type": "object",
      "required": [
        "columns",
        "image",
        "image_height",
        "image_width",
        "name",
        "tile_count",
        "tile_height",
        "tile_width"
      ],
      "properties": {
        "columns": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0.0
        },
        "first_gid": {
          "description": "Only present in inline tilesets within a map file. Absent in standalone .cartile-ts files.",
          "type": "integer",
          "format": "uint32",
          "minimum": 0.0
        },
        "image": {
          "type": "string"
        },
        "image_height": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0.0
        },
        "image_width": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0.0
        },
        "margin": {
          "default": 0,
          "type": "integer",
          "format": "uint32",
          "minimum": 0.0
        },
        "name": {
          "type": "string"
        },
        "spacing": {
          "default": 0,
          "type": "integer",
          "format": "uint32",
          "minimum": 0.0
        },
        "tile_count": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0.0
        },
        "tile_height": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0.0
        },
        "tile_width": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0.0
        },
        "tiles": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/definitions/TileData"
          }
        }
      },
      "additionalProperties": true
    },
    "TilesetEntry": {
      "anyOf": [
        {
          "$ref": "#/definitions/TilesetRef"
        },
        {
          "$ref": "#/definitions/Tileset"
        }
      ]
    },
    "TilesetRef": {
      "type": "object",
      "required": [
        "$ref",
        "first_gid"
      ],
      "properties": {
        "$ref": {
          "type": "string"
        },
        "first_gid": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0.0
        }
      }
    },
    "Topology": {
      "type": "string",
      "enum": [
        "bounded",
        "wrap_x",
        "wrap_y",
        "wrap_xy"
      ]
    }
  }
}